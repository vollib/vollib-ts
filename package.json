{
  "name": "vollib",
  "version": "0.1.0",
  "description": "TypeScript option pricing, implied volatility, and Greeks built on LetsBeRational.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./black": {
      "types": "./dist/src/black.d.ts",
      "import": "./dist/src/black.js"
    },
    "./blackScholes": {
      "types": "./dist/src/blackScholes.d.ts",
      "import": "./dist/src/blackScholes.js"
    },
    "./blackScholesMerton": {
      "types": "./dist/src/blackScholesMerton.d.ts",
      "import": "./dist/src/blackScholesMerton.js"
    },
    "./greeks": {
      "types": "./dist/src/greeks.d.ts",
      "import": "./dist/src/greeks.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "dependencies": {
    "lets-be-rational": "file:../lets-be-rational-ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
